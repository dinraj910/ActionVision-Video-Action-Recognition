# ============================================================
# .env.example – Copy to .env and fill in values
# ============================================================

# ── Model ─────────────────────────────────────────────────
# Absolute or relative path to the trained Keras model file
MODEL_PATH=model/final_video_action_model.keras

# Path to a plain-text file with one class label per line
# (optional – falls back to built-in default labels)
LABELS_PATH=model/class_labels.txt

# ── Server ────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info

# ── Upload limits ─────────────────────────────────────────
MAX_UPLOAD_MB=100

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * only during development.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Gunicorn ──────────────────────────────────────────────
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120
